# Copy this file to .env and fill in the values. Do not commit .env to Git.

DEBUG=True
SECRET_KEY=your-secret-key-min-50-chars

# CRM24 webhook (required)
CRM_WEBHOOK_BASE=https://your-company.crm24.ru/rest/1/your_webhook_key

# OpenAI API (for AI analytics)
GPT_MODEL_TYPE=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Database (MySQL by default; provide your own values)
DB_ENGINE=django.db.backends.mysql
DB_NAME=my_database
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306
