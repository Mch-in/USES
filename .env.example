# Скопируйте в .env и заполните значения. Файл .env не коммитить в Git.

DEBUG=True
SECRET_KEY=your-secret-key-min-50-chars

# CRM24 webhook (обязательно)
CRM_WEBHOOK_BASE=https://your-company.crm24.ru/rest/1/your_webhook_key

# OpenAI API (для AI-анализа)
GPT_MODEL_TYPE=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Опционально: БД (по умолчанию MySQL; см. salary/settings.py)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=my_database
# DB_USER=root
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=3306
